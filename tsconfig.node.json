{
  "compilerOptions": {
    "incremental": true,
    "composite": true,
    "lib": [
      "es2024",
      "ESNext.Array",
      "ESNext.Collection",
      "ESNext.Error",
      "ESNext.Iterator",
      "ESNext.Promise"
    ],
    "baseUrl": ".",
    "rootDir": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["envs", "**.config.ts", "**/configs/*", "**/types/*", "**/config/*", "package.json"],
  "exclude": ["node_modules", "src"]
}
