{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "composite": true,
    "baseUrl": ".",
    "rootDir": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": [
    "node_modules",
    "src"
  ]
}
