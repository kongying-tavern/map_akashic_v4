{
  "compilerOptions": {
    "incremental": true,
    "composite": true,
    "lib": [
      "es2024",
      "ESNext",
      "ESNext.Array",
      "ESNext.Collection",
      "ESNext.Error",
      "ESNext.Iterator",
      "ESNext.Promise"
    ],
    "baseUrl": "./",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node", "./types/experimental.node.d.ts"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.buildinfo"
  },
  "include": ["envs", "**.config.ts", "types", "infrastructure", "package.json"],
  "exclude": ["node_modules", "src"]
}
